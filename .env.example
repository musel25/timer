# Copy to .env on the server and fill in. Never commit the real .env.

# Port the container listens on internally (compose maps 127.0.0.1:8002 -> 8080)
PORT=8080

# SQLite database path (inside the container this is the mounted volume)
TIMER_DB=/data/timer.db

# Long random string used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-secret

# The single account that gets created on first boot (closed signup).
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change-me

NODE_ENV=production

# --- Claude Code dashboard (local dev only; the /cc routes are disabled when
# NODE_ENV=production). Shared secret the Claude Code hooks send as the X-CC-Token
# header to POST /cc/ingest. Set the same value in ~/.claude/settings.json. Leave
# empty to disable the token check (fine for a purely-local, localhost-only setup).
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
CC_DASH_TOKEN=
